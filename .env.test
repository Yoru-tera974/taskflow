# ============================================================
# .env.test — Configuration environnement TEST / CI
# TaskFlow — TP Fil Rouge CI/CD — Noel Evan
# Ce fichier PEUT être commité (pas de vrais secrets)
# ============================================================

NODE_ENV=test
PORT=8081

# Base de données test (isolée de la prod)
DB_HOST=db-test.taskflow.local
DB_PORT=5432
DB_NAME=taskflow_test
DB_USER=test_user
DB_PASSWORD=test_password_ci

# JWT
JWT_SECRET=test_secret_ci_pipeline
JWT_EXPIRES=1h

# Logs
LOG_LEVEL=info

# Docker
DOCKER_IMAGE=taskflow
DOCKER_PORT=8080
