# ============================================================
# .env.dev — Configuration environnement DÉVELOPPEMENT
# TaskFlow — TP Fil Rouge CI/CD — Noel Evan
# Ce fichier PEUT être commité (pas de vrais secrets)
# ============================================================

NODE_ENV=development
PORT=8082

# Base de données locale
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow_dev
DB_USER=dev_user
DB_PASSWORD=dev_password_local

# JWT (non sensible en dev)
JWT_SECRET=dev_secret_non_sensible_change_en_prod
JWT_EXPIRES=24h

# Logs
LOG_LEVEL=debug

# Docker (cohérence avec TP IaC Terraform)
DOCKER_IMAGE=taskflow
DOCKER_PORT=8080
